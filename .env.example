NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000

# MySQL
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=hotel_booking

# Sessions
SESSION_SECRET=change_me_to_a_long_random_value

# Admin seed (create on first run if not present)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminPass123!

# Email (optional but included)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM="Hotel Booking" <no-reply@example.com>

# Pesapal v3 (sandbox)
PESAPAL_ENV=sandbox
PESAPAL_CONSUMER_KEY=your_sandbox_consumer_key
PESAPAL_CONSUMER_SECRET=your_sandbox_consumer_secret
# OPTIONAL: If you pre-register an IPN URL in Pesapal portal, set its ID here.
# Otherwise, the app can attempt to register and store it.
PESAPAL_IPN_ID=

# Currency
CURRENCY=KES
